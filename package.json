{
  "name": "vancedmovies",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bun run type-check && bunx --bun vite build",
    "type-check": "bunx --bun tsc --noEmit",
    "lint": "bunx --bun eslint --fix",
    "lint:check": "bunx --bun eslint",
    "preview": "bunx --bun vite preview",
    "clean": "rm -rf dist node_modules/.vite",
    "install:clean": "rm -rf node_modules bun.lockb && bun install",
    "format": "bunx --bun prettier --write .",
    "format:check": "bunx --bun prettier --check ."
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "7.15.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.5.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vite-tsconfig-paths": "6.1.1"
  }
}