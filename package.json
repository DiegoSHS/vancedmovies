{
  "name": "vancedmovies",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bun run type-check && bunx --bun vite build",
    "type-check": "bunx --bun tsc --noEmit",
    "lint": "bunx --bun eslint --fix",
    "lint:check": "bunx --bun eslint",
    "preview": "bunx --bun vite preview",
    "clean": "rm -rf dist node_modules/.vite",
    "install:clean": "rm -rf node_modules bun.lockb && bun install",
    "format": "bunx --bun prettier --write .",
    "format:check": "bunx --bun prettier --check ."
  },
  "dependencies": {
    "@heroui/react": "^3.0.1",
    "baseline-browser-mapping": "^2.10.10",
    "caniuse-lite": "^1.0.30001781",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.23.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.8",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.25.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "20.5.7",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/webtorrent": "^0.110.0",
    "@typescript-eslint/eslint-plugin": "8.31.1",
    "@typescript-eslint/parser": "8.31.1",
    "@vitejs/plugin-react": "4.4.1",
    "autoprefixer": "10.4.21",
    "eslint": "9.25.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "16.0.0",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "typescript": "5.6.3",
    "vite": "5.2.0",
    "vite-tsconfig-paths": "4.3.2"
  }
}